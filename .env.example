# Supabase (use existing Grow project for shared auth + DB)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Frontend Supabase anon key (Vite-inlined, public by design)
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Apify — Google Maps scraper
# Sign up: https://apify.com → Settings → Integrations → API token
APIFY_TOKEN=apify_api_xxx

# AICre8 API — for generating preview sites
AICRE8_API_KEY=ak_live_xxx
AICRE8_API_URL=https://aicre8.dev

# Resend — outreach emails
# Sign up: https://resend.com → API Keys
RESEND_API_KEY=re_xxx
EMAIL_FROM=leads@yourdomain.com

# Cron protection — any long random string
CRON_SECRET=run `openssl rand -hex 32` and paste

# Stripe — credit checkout
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional local/dev fallback until the Grow shell sends Supabase auth
GROW_DEMO_USER_ID=00000000-0000-0000-0000-000000000000
